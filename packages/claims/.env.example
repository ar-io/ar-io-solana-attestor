# ar-io-claims — example environment (M0 scaffold).
#
# Copy to `.env` for local dev and fill in real values. NEVER commit a
# populated `.env` — it is gitignored. Production injects these from a
# secret manager, never a file. NO SECRETS belong in this example.

# Postgres connection string. docker-compose injects this automatically
# pointing at the `postgres` service. For bare local runs, point it at
# your own instance. The credentials below match the throwaway local
# docker-compose Postgres and are NOT production credentials.
DATABASE_URL=postgres://claims:claims@localhost:5432/claims

# HTTP listener.
PORT=3040
HOST=0.0.0.0

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Which Solana deployment this service targets. Must match the on-chain
# NETWORK constant. One of: solana-mainnet | solana-devnet | localnet
NETWORK=localnet

# Solana RPC endpoint (@solana/kit). Defaults per NETWORK when unset.
# SOLANA_RPC_URL=http://127.0.0.1:8899

# --- Reserved for later milestones (documented here, unused in M0) ---
# TREASURY_SECRET_*   — dispensing key material (M4); load from KMS, not env.
# AUDIT_SECRET_*      — audit-log signing key (M6).
# ATTESTOR_URL        — attestor base URL for evidentiary re-attestation (M2).
