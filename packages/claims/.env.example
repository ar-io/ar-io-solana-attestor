# ar-io-claims — example environment (M0 scaffold).
#
# Copy to `.env` for local dev and fill in real values. NEVER commit a
# populated `.env` — it is gitignored. Production injects these from a
# secret manager, never a file. NO SECRETS belong in this example.

# Postgres connection string. docker-compose injects this automatically
# pointing at the `postgres` service. For bare local runs, point it at
# your own instance. The credentials below match the throwaway local
# docker-compose Postgres and are NOT production credentials.
DATABASE_URL=postgres://claims:claims@localhost:5432/claims

# HTTP listener.
PORT=3040
HOST=0.0.0.0

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Which Solana deployment this service targets. Must match the on-chain
# NETWORK constant. One of: solana-mainnet | solana-devnet | localnet
NETWORK=localnet

# Solana RPC endpoint (@solana/kit). Defaults per NETWORK when unset.
# SOLANA_RPC_URL=http://127.0.0.1:8899

# --- M1: ledger build + reconciliation ---
# Frozen mainnet capture dir (the ledger's source inputs).
# FROZEN_INPUTS_DIR=/programs/ario-snapshot/output-mainnet-prod-remediation
# Per-migration ANT mint secret (base64 of 32 bytes). SECRET — inject from a
# secret manager, NEVER commit. Must equal the snapshot/import operator's value.
# ANT_MINT_SECRET=
# Reference "now" pinning the vault/stake liquid-vs-vault split (deterministic
# ledger). Default 1783641600000 = 2026-07-10T00:00:00Z (reproduces the gate).
# LEDGER_NOW_MS=1783641600000
# AO process id whose self-balance is the protocol reserve (excluded from token
# escrow). Defaults to the mainnet id.
# AO_PROCESS_ID=qNvAoz0TgcH7DMg8BCVn8jF32QH5L6T29VjHxhHqqGE
# Reconciliation (local/ops gate — NOT wired into CI):
# RECONCILE_SOURCE=db  # db (persisted ledger) | plan (in-memory)
# SOLANA_AR_IO_IMPORT_SRC=/home/vilenarios/source/solana-ar-io/migration/import/src

# --- M3: claims API + replay/double-claim defense ---
# TTL of the single-use claim challenge (ms). A claim not completed within this
# window expires and its nonce is dead. Default 15 min.
# CLAIM_CHALLENGE_TTL_MS=900000
# Big-claim brake (§4.3): a claim whose asset amount (or the recipient's total
# unclaimed) exceeds this routes to pending_review for operator approval instead
# of auto-dispatch. mARIO. Default 100,000 ARIO = 100000000000.
# BIG_CLAIM_THRESHOLD_MARIO=100000000000
# Rate limits (fixed 1-minute window). Per-IP caps the whole /v1 surface;
# per-identity caps the identity-bearing routes. 0 disables a dimension.
# RATE_LIMIT_PER_MIN=60
# RATE_LIMIT_IDENTITY_PER_MIN=20
# CORS Access-Control-Allow-Origin ("*" or a specific origin).
# CORS_ORIGIN=*

# --- M4: dispatch + custody ---
# ARIO SPL mint the dispenser transfers (required by the dispatch worker).
# ARIO_MINT=
# ario-core program id — enables the vault RE-LOCK settlement path. Optional.
# ARIO_CORE_PROGRAM=
#
# TREASURY (hot dispenser) KEY — holds ONLY the bounded ARIO float + ANT-less.
# The seed is AES-256-GCM SEALED at rest (crypto-box.ts); the passphrase (KEK)
# is injected SEPARATELY at runtime. NEVER commit either. Produce the sealed
# blob with `yarn encrypt:treasury-key --generate --out <path>`.
# TREASURY_KEY_SEALED_PATH=/run/secrets/treasury.sealed.json
# TREASURY_KEY_PASSPHRASE=            # runtime KEK — from a secret manager, NOT a file
# TREASURY_SEED_BASE64=               # localnet/tests ONLY (unencrypted 32-byte seed)
#
# ANT custody — DECISION: cold authority, signed PER APPROVAL BATCH. The cold
# ANT authority is OPERATOR-SUPPLIED at approval time (NOT a persistent server
# key; NO bulk-move of the 2,269 ANTs). Run `yarn dispatch:ants` with the cold
# key loaded for THIS batch only; it dispenses every approved ANT then discards
# the signer. Provide ONE of:
# ANT_COLD_KEYPAIR_PATH=/path/to/cold-authority.json   # a Solana CLI keypair JSON
# ANT_COLD_KEY_SEALED_PATH=/run/secrets/ant-cold.sealed.json
# ANT_COLD_KEY_PASSPHRASE=
# ANT_REQUIRES_APPROVAL=true          # false to auto-dispense ANTs (NOT recommended)
#
# (Optional, discouraged) a PERSISTENT server-side ant signer — only if a
# deployment explicitly opts out of the per-batch cold-key model:
# ANT_SIGNER_KEY_SEALED_PATH=/run/secrets/ant-signer.sealed.json
# ANT_SIGNER_KEY_PASSPHRASE=
# ANT_SIGNER_SEED_BASE64=             # localnet/tests ONLY
#
# Hot-float policy (mARIO). Cap ~500k ARIO; refill signal at 20% of cap.
# HOT_FLOAT_CAP_MARIO=500000000000
# FLOAT_REFILL_THRESHOLD_MARIO=100000000000
#
# Live ario-core ArioConfig.min/max_vault_duration (seconds) for vault settlement.
# VAULT_MIN_DURATION_SECONDS=1209600  # 14 days
# VAULT_MAX_DURATION_SECONDS=31536000 # 365 days
#
# Worker poll interval (ms).
# DISPATCH_POLL_INTERVAL_MS=5000
#
# Confirmation-read RPC (exactly-once depends on it): the getSignatureStatuses +
# getBlockHeight reads MUST use a SINGLE consistent endpoint (or read quorum),
# NOT a round-robin/load-balanced pool — a lagging replica can misclassify a
# landed tx as dead and cause a double-send. Defaults to SOLANA_RPC_URL.
# CONFIRM_RPC_URL=https://your-single-consistent-endpoint

# --- M6: transparency (signed ledger + anchored audit log + reserves) ---
# Two Ed25519 keys, SEPARATE from the treasury + attestor keys (BUILD.md). Sealed
# at rest (AES-256-GCM) with the passphrase injected separately; a bare seed is
# localnet/tests ONLY. Seal with `tsx src/cli/encrypt-treasury-key.ts` reused, or
# provide the base64 seed for a proof run. NEVER commit either.
#
# AUDIT key — signs each audit_log.entry_hash (!= attestor, != treasury).
# AUDIT_KEY_SEALED_PATH=/run/secrets/audit.sealed.json
# AUDIT_KEY_PASSPHRASE=
# AUDIT_SEED_BASE64=                 # localnet/tests only (32-byte seed, base64)
# AUDIT_PUBKEY_HEX=                  # published audit pubkey (for verifiers)
#
# LEDGER_PUBLISHER key — signs the published-ledger manifest AND is the fee-payer
# /signer of the on-chain anchor memo tx (needs a little SOL on the anchor cluster).
# LEDGER_PUBLISHER_KEY_SEALED_PATH=/run/secrets/publisher.sealed.json
# LEDGER_PUBLISHER_KEY_PASSPHRASE=
# LEDGER_PUBLISHER_SEED_BASE64=      # localnet/tests only
# LEDGER_PUBLISHER_PUBKEY_HEX=       # published publisher pubkey (for verifiers + pinning)
#
# Key-reuse guard (LOW #5): the publish/anchor CLIs assert the audit + publisher
# keys differ from the treasury + attestor keys. Supply the PUBLIC addresses so
# the guard can catch a reused key (TREASURY_ADDRESS is shared with reserves below).
# ATTESTOR_PUBKEY_BASE58=            # attestor pubkey as a base58 Solana address
# ATTESTOR_PUBKEY_HEX=               # or the attestor pubkey as hex
#
# Publish/anchor knobs.
# LEDGER_VERSION=                    # version label for a publish (default: ISO ts)
# LEDGER_FINGERPRINTS_PATH=          # optional JSON of frozen-input sha256s
# ANCHOR_TARGET=solana-memo          # solana-memo | arweave (extension) | none
# ANCHOR_MEMO_PROGRAM=Memo1UhkJRfHyvLMcVucJwxXeuD728EqVDDwQDxFMNo  # live memo program
#
# Reserves endpoint (GET /v1/transparency/reserves) — reserve side read LIVE on-chain.
# TREASURY_ADDRESS=                  # hot dispenser owner (its ATA = hot float)
# COLD_RESERVE_ADDRESS=              # cold reserve owner (its ATA = cold reserve)
# ANT_AUTHORITY_ADDRESS=             # authority whose ANT ownership is verified
# RESERVES_ANT_CHECK=off             # off | sample | gpa (gpa = full getProgramAccounts)
# RESERVES_ANT_SAMPLE_SIZE=25
# (ARIO_MINT is shared with the M4 dispatch config above.)
#
# --- Reserved (documented here, unused so far) ---
# ATTESTOR_URL        — attestor base URL for evidentiary re-attestation.
