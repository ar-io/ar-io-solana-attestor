{
  "name": "@ar.io/escrow-attestor",
  "version": "0.1.0",
  "private": true,
  "description": "Off-chain RSA-PSS verifier + Ed25519 attestor for ar-io ANT escrow Arweave claims. Replaces the on-chain RSA modexp path (sol_big_mod_exp is blocked on all public Solana clusters).",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "node --test --import tsx src/integration.test.ts src/app.test.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "keygen": "tsx src/keygen.ts"
  },
  "dependencies": {
    "@ar.io/attestor-canonical": "0.1.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "bs58": "^6.0.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
